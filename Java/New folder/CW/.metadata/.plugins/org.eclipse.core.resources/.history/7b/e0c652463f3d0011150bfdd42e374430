package session_13;

public class JoinDemo implements Runnable{

	@Override
	public void run() {
		for(int i=1;i<=3;i++)
		{
			try {
				Thread.sleep(500);
			} catch (InterruptedException e) {
				e.printStackTrace();
			}
			System.out.println(Thread.currentThread()
					.getName()+
					" "+i);
		}	
		
	}

}
