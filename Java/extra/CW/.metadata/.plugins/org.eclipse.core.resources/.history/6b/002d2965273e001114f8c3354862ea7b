package session_14;

public class Customer {
	
	private int balance;
	
	public Customer()
	{
		balance = 5000;
	}
	
	public synchronized int deposit(int amount) throws InterruptedException
	{
		if(this.balance<amount)
		{
			System.out.println("Insufficient Funds");
			wait();
		}
		else
		{
			this.balance+=amount;
		}
		
	}

}
