package session_13;

public class Account {
	
	private int balance;
	
	public Account() {
		balance = 5000;
	}
	
	public void deposit(int amount) throws InterruptedException
	{
		System.out.println(Thread.currentThread().getName()+" started");
		int temp;
		temp = balance;
		temp+=amount;
		Thread.currentThread().sleep(1000);
		balance = temp;
	}
	
	

}
