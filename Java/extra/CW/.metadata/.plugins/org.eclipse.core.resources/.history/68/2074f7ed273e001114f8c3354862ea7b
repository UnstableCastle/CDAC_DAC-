package session_14;

public class Customer {
	
	private int balance;
	
	public Customer()
	{
		balance = 5000;
	}
	
	public synchronized int withdraw(int balance) throws InterruptedException
	{
		if(this.balance<balance)
		{
			System.out.println("Insufficient Funds");
			wait();
		}
		else
		{
			this.balance-=balance;
		}
		
		return this.balance;
	}
	
	public synchronized void deposit(int amount)
	{
		this.balance+=amount;
		notify();
	}

}
