package session_11;

import java.util.Arrays;
import java.util.List;

public class Demo6 {
	
	public static void main(String[] args) {
		List<Integer> list = Arrays.asList(10,56,78,11,13,7,4);
		//iterate
		//all even nos
		//double
		//sum
		
		int sum1 = 0;
		System.out.println("--------------");
		for(int i:list)
		{
			if((i%2) == 0)
			{
				System.out.println(i);
				i = i*2;
				sum1+=i;
			}	
		}
		System.out.println("Sum = "+sum1);
		
		
	int total =	list.stream().filter(i -> i%2==0).map(a -> a*2).reduce(1, Integer::sum);
		System.out.println("Total = "+total);
	}

}
